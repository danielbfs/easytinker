// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH (NextAuth) ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  tinkerCredentials TinkerCredential?
  projects          Project[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ─── TINKER CREDENTIALS ────────────────────────────────────────────────────────

model TinkerCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  encryptedKey String   // AES-256-GCM ciphertext (hex)
  iv           String   // initialization vector (hex)
  authTag      String   // GCM auth tag (hex)
  isValid      Boolean  @default(false)
  validatedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── PROJECTS ──────────────────────────────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  baseModel   String   // e.g. "Qwen/Qwen3-8B"
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  dataSources DataSource[]
  trainingJobs TrainingJob[]

  @@index([userId])
}

enum ProjectStatus {
  DRAFT
  READY
  TRAINING
  COMPLETED
  FAILED
}

// ─── DATA SOURCES ──────────────────────────────────────────────────────────────

model DataSource {
  id          String         @id @default(cuid())
  projectId   String
  type        DataSourceType
  name        String
  filePath    String?        // for file uploads
  url         String?        // for URL sources
  content     String?        // extracted text content
  sizeBytes   Int?
  mimeType    String?
  status      DataSourceStatus @default(PENDING)
  errorMsg    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

enum DataSourceType {
  FILE_UPLOAD
  URL_LINK
  GOOGLE_DRIVE  // Phase 2
  SHAREPOINT    // Phase 2
}

enum DataSourceStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

// ─── TRAINING JOBS ─────────────────────────────────────────────────────────────

model TrainingJob {
  id              String      @id @default(cuid())
  projectId       String
  baseModel       String
  loraRank        Int         @default(32)
  learningRate    Float       @default(0.0001)
  epochs          Int         @default(3)
  batchSize       Int         @default(4)
  lossFunction    String      @default("cross_entropy")
  status          JobStatus   @default(PENDING)
  errorMsg        String?
  checkpointPath  String?     // tinker:// path
  currentEpoch    Int?
  totalSteps      Int?
  currentStep     Int?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  metrics   JobMetric[]

  @@index([projectId])
  @@index([status])
}

enum JobStatus {
  PENDING
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

// ─── JOB METRICS ───────────────────────────────────────────────────────────────

model JobMetric {
  id        String   @id @default(cuid())
  jobId     String
  step      Int
  epoch     Int
  loss      Float
  timestamp DateTime @default(now())

  job TrainingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([jobId, step])
}
