# ═══════════════════════════════════════════════════════════════════════════════
# EaseTinker — Environment Variables
# Copy this file to .env.local (dev) or .env (prod) and fill in the values.
# NEVER commit the actual .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── APP ───────────────────────────────────────────────────────────────────────
# Your domain (no https://)
APP_DOMAIN=easetinker.example.com
NEXTAUTH_URL=https://easetinker.example.com
NODE_ENV=production

# ─── AUTHENTICATION ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── ENCRYPTION ────────────────────────────────────────────────────────────────
# Used to encrypt Tinker API keys at rest (AES-256-GCM)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── DATABASE ──────────────────────────────────────────────────────────────────
POSTGRES_USER=easetinker
POSTGRES_PASSWORD=
POSTGRES_DB=easetinker
DATABASE_URL=postgresql://easetinker:CHANGE_ME@postgres:5432/easetinker

# ─── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ─── PYTHON WORKER ─────────────────────────────────────────────────────────────
# Internal URL — do not change in production (docker service name)
WORKER_URL=http://worker:8000
# Shared secret for Next.js <-> Worker auth
# Generate with: openssl rand -hex 32
WORKER_SECRET=

# ─── FILE UPLOAD ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/data/uploads
