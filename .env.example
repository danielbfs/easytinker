# ═══════════════════════════════════════════════════════════════════════════════
# EaseTinker — Environment Variables
# Copy this file to .env.local (dev) or .env (prod) and fill in the values.
# NEVER commit the actual .env file to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── APP ───────────────────────────────────────────────────────────────────────
# Your domain (no https://)
APP_DOMAIN=easetinker.example.com
NODE_ENV=production

# ─── AUTHENTICATION (OAuth providers) ──────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── DATABASE ──────────────────────────────────────────────────────────────────
POSTGRES_USER=easetinker
POSTGRES_DB=easetinker

# ─── FILE UPLOAD ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=/data/uploads

# ═══════════════════════════════════════════════════════════════════════════════
# Technical secrets — NOT listed here on purpose.
#
# The `init-secrets` container in docker-compose.yml generates these on the
# first deploy and persists them in the `secrets` named volume. The app and
# worker containers read them from /secrets/ at startup via the entrypoint
# script (docker/docker-entrypoint.sh).
#
# Generated automatically on first deploy:
#   - postgres-password  → POSTGRES_PASSWORD       (DB superuser)
#   - nextauth-secret    → NEXTAUTH_SECRET         (JWT signing)
#   - encryption-key     → ENCRYPTION_KEY          (AES-256-GCM for API keys)
#   - worker-secret      → WORKER_SECRET           (Next.js ↔ Worker auth)
#
# To rotate any of them: delete the file in the volume and recreate the
# affected container — init-secrets will regenerate just the missing files.
# ═══════════════════════════════════════════════════════════════════════════════
